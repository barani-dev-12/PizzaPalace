MONGO_URI=your_mongodb_atlas_connection_string
NODE_ENV=production
JWT_SECRET=use_a_long_random_secret_at_least_32_characters
JWT_EXPIRES_IN=7d
# Razorpay (required on Render for online payments; COD works without these)
KEY_ID=rzp_test_your_razorpay_key_id
KEY_SECRET=your_razorpay_key_secret
# Optional aliases (same values):
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
CLIENT_URL=https://your-app.vercel.app
